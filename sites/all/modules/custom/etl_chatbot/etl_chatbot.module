<?php

/**
 * Implements hook_init().
 */
function etl_chatbot_init() {
  global $user;

  if ($user->uid > 0) {
    $module_path = drupal_get_path('module', 'etl_chatbot');

    drupal_add_js($module_path . '/js/etl_chatbot.js');
    drupal_add_css($module_path . '/css/etl_chatbot.css');
    drupal_add_library('system', 'drupal.ajax');

    drupal_add_html_head(array(
      '#tag' => 'meta',
      '#attributes' => array(
        'name' => 'viewport',
        'content' => 'width=device-width, initial-scale=1',
      ),
    ), 'etl_chatbot_viewport');

    drupal_add_js(array(
      'etl_chatbot' => array(
        'ajax_url' => url('etl-chatbot/ajax', array('absolute' => TRUE)),
      ),
    ), 'setting');
  }
}

/**
 * Implements hook_menu().
 */
function etl_chatbot_menu() {

  $items['etl-chatbot/ajax'] = array(
    'page callback' => 'etl_chatbot_ajax_callback',
    'access arguments' => array('access content'),
    'type' => MENU_CALLBACK,
  );

  return $items;
}

/**
 * Implements hook_page_alter().
 * Injects chatbot markup at page bottom.
 */
function etl_chatbot_page_alter(&$page) {
  global $user;
  if ($user->uid == 0) return;

  $page['page_bottom']['etl_chatbot'] = array(
    '#theme' => 'etl_chatbot',
    '#today' => date('Y-m-d'),
  );
}

/**
 * Implements hook_theme().
 */
function etl_chatbot_theme($existing, $type, $theme, $path) {
  return array(
    'etl_chatbot' => array(
      'variables' => array(
        'today' => date('Y-m-d'),
      ),
      'template' => 'etl-chatbot',
      'path' => drupal_get_path('module', 'etl_chatbot') . '/templates',
    ),
  );
}

/**
 * AJAX callback.
 */
function etl_chatbot_ajax_callback() {
  global $user;

  $query = isset($_POST['query']) ? strtolower(trim(filter_xss($_POST['query']))) : '';
  $response = etl_chatbot_process_query($query, $user->uid);

  drupal_json_output(array('response' => $response));
  drupal_exit();
}

/**
 * Chatbot query processing logic.
 */
function etl_chatbot_process_query($query, $uid) {

  if ($uid == 0) {
    return t('Please login.');
  }

  $greetings = array('hi','hello','hey','greetings');

  foreach ($greetings as $g) {
    if (strpos($query, $g) !== FALSE) {
      return t('Hello! How can I assist you with your reminders today?');
    }
  }

  if (strpos($query, 'today') !== FALSE) {
    return etl_chatbot_get_reminders_by_date(date('Y-m-d'), $uid);
  }

  if (strpos($query, 'upcoming') !== FALSE || strpos($query, 'next') !== FALSE) {
    return etl_chatbot_get_upcoming_reminders($uid);
  }

  if (preg_match('/(\d{4}-\d{2}-\d{2})/', $query, $m)) {
    return etl_chatbot_get_reminders_by_date($m[1], $uid);
  }

  if (strpos($query, 'progress') !== FALSE || strpos($query, 'stat') !== FALSE) {
    return etl_chatbot_get_progress_stats($uid);
  }

  return t('Sorry, I did not understand.');
}

/**
 * Get upcoming reminders.
 */
function etl_chatbot_get_upcoming_reminders($uid) {

  $today = date('Y-m-d');

  $q = db_select('node', 'n');
  $q->join('field_data_field_reminder_date', 'rd', 'rd.entity_id = n.nid');
  $q->join('field_data_field_learning_status', 'ls', 'ls.entity_id = n.nid');

  $q->fields('n', array('nid', 'title'));
  $q->addField('rd', 'field_reminder_date_value', 'date');

  $q->condition('n.type', 'deferred_item');
  $q->condition('n.uid', $uid);
  $q->condition('ls.field_learning_status_value', 'Pending');
  $q->condition('rd.field_reminder_date_value', $today, '>');

  $q->range(0, 6);

  $r = $q->execute()->fetchAll();

  if (!$r) {
    return t('No upcoming reminders.');
  }

  $out = '<b>' . t('Upcoming Reminders:') . '</b><div class="etl-cards">';
  $count = count($r);
  $showCount = min(5, $count);

  for ($i = 0; $i < $showCount; $i++) {
    $row = $r[$i];
    $url = url('node/' . $row->nid, array('absolute' => TRUE));
    $time = format_date(strtotime($row->date), 'custom', 'Y-m-d H:i');

    $out .= '<div class="etl-card">
                <div class="etl-card-title">' . check_plain($row->title) . '</div>
                <div class="etl-card-time">' . check_plain($time) . '</div>
                <button class="etl-btn-view" data-url="' . check_plain($url) . '">' . t('View') . '</button>
             </div>';
  }

  if ($count > 5) {
    $out .= '<div class="etl-more">' . t('and more...') . '</div>';
  }

  $out .= '</div>';
  return $out;
}

/**
 * Get reminders for specific date.
 */
function etl_chatbot_get_reminders_by_date($date, $uid) {

  $start = $date.' 00:00:00';
  $end = $date.' 23:59:59';

  $q = db_select('node', 'n');
  $q->join('field_data_field_reminder_date', 'rd', 'rd.entity_id = n.nid');

  $q->fields('n', array('nid', 'title'));
  $q->addField('rd', 'field_reminder_date_value', 'date');

  $q->condition('n.type', 'deferred_item');
  $q->condition('n.uid', $uid);
  $q->condition('rd.field_reminder_date_value', array($start, $end), 'BETWEEN');

  $q->range(0, 6);

  $r = $q->execute()->fetchAll();

  if (!$r) {
    return t('No reminders found.');
  }

  $out = '<b>' . t('Reminders for @date:', array('@date' => check_plain($date))) . '</b><div class="etl-cards">';
  $count = count($r);
  $showCount = min(5, $count);

  for ($i = 0; $i < $showCount; $i++) {
    $row = $r[$i];
    $url = url('node/' . $row->nid, array('absolute' => TRUE));
    $time = format_date(strtotime($row->date), 'custom', 'H:i');

    $out .= '<div class="etl-card">
                <div class="etl-card-title">' . check_plain($row->title) . '</div>
                <div class="etl-card-time">' . check_plain($time) . '</div>
                <button class="etl-btn-view" data-url="' . check_plain($url) . '">' . t('View') . '</button>
             </div>';
  }

  if ($count > 5) {
    $out .= '<div class="etl-more">' . t('and more...') . '</div>';
  }

  $out .= '</div>';
  return $out;
}

/**
 * Get progress statistics.
 */
function etl_chatbot_get_progress_stats($uid) {

  $base = db_select('node', 'n');
  $base->join('field_data_field_learning_status', 'ls', 'ls.entity_id = n.nid');
  $base->condition('n.type', 'deferred_item');
  $base->condition('n.uid', $uid);

  $learned = (clone $base)
    ->condition('ls.field_learning_status_value', 'Learned')
    ->countQuery()
    ->execute()
    ->fetchField();

  $pending = (clone $base)
    ->condition('ls.field_learning_status_value', 'Pending')
    ->countQuery()
    ->execute()
    ->fetchField();

  $dropped = (clone $base)
    ->condition('ls.field_learning_status_value', 'Dropped')
    ->countQuery()
    ->execute()
    ->fetchField();

  $total = $learned + $pending + $dropped;
  $completion = $total ? round($learned / $total * 100) : 0;

  return "
  <b>" . t('Progress:') . "</b>
  <div class='etl-cards'>
    <div class='etl-card'><div>" . t('Total: @count', array('@count' => $total)) . "</div></div>
    <div class='etl-card'><div>" . t('Learned: @count', array('@count' => $learned)) . "</div></div>
    <div class='etl-card'><div>" . t('Pending: @count', array('@count' => $pending)) . "</div></div>
    <div class='etl-card'><div>" . t('Dropped: @count', array('@count' => $dropped)) . "</div></div>
    <div class='etl-card'><div>" . t('Completion: @percent%', array('@percent' => $completion)) . "</div></div>
  </div>";
}